namespace := "kafka"

# Deploy the full Kafka cluster (Kafka CR + node pools + topics + users)
install:
    kubectl create namespace {{ namespace }} --dry-run=client -o yaml | kubectl apply -f -
    kubectl apply -n {{ namespace }} -f kafka.yaml -f broker.yaml -f controller.yaml
    @echo "Waiting for Kafka cluster to be ready..."
    kubectl wait kafka/core --for=condition=Ready --timeout=300s -n {{ namespace }} || true
    kubectl apply -n {{ namespace }} -f topics.yaml -f users.yaml
    @echo "Kafka cluster deployed."

# Show cluster status
status:
    kubectl get kafka,kafkanodepool,kafkatopic,kafkauser -n {{ namespace }}

# Show mTLS secrets generated by Strimzi for Portfolio users
secrets:
    @echo "=== core-portfolio-producer ==="
    kubectl get secret core-portfolio-producer -n {{ namespace }} -o jsonpath='{.data}' | jq -r 'keys[]'
    @echo ""
    @echo "=== portfolio-consumer ==="
    kubectl get secret portfolio-consumer -n {{ namespace }} -o jsonpath='{.data}' | jq -r 'keys[]'

# Extract client cert+key for a given user (e.g. just user=core-portfolio-producer)
extract-certs user:
    mkdir -p certs/{{ user }}
    kubectl get secret {{ user }} -n {{ namespace }} -o jsonpath='{.data.ca\.crt}' | base64 -d > certs/{{ user }}/ca.crt
    kubectl get secret {{ user }} -n {{ namespace }} -o jsonpath='{.data.user\.crt}' | base64 -d > certs/{{ user }}/user.crt
    kubectl get secret {{ user }} -n {{ namespace }} -o jsonpath='{.data.user\.key}' | base64 -d > certs/{{ user }}/user.key
    @echo "Certs written to certs/{{ user }}/"

# Test producing to portfolio-wallet-events via mTLS using extracted certs
test-produce user="core-portfolio-producer":
    kubectl run kafka-producer --rm -it --image=quay.io/strimzi/kafka:latest-kafka-3.7.1 -n {{ namespace }} --restart=Never -- \
      bin/kafka-console-producer.sh \
        --bootstrap-server core-kafka-bootstrap:9093 \
        --topic portfolio-wallet-events \
        --producer-property security.protocol=SSL \
        --producer-property ssl.truststore.type=PEM \
        --producer-property ssl.truststore.location=/tmp/ca.crt \
        --producer-property ssl.keystore.type=PEM \
        --producer-property ssl.keystore.location=/tmp/user.crt \
        --producer-property ssl.key.location=/tmp/user.key

# Test consuming from portfolio-wallet-events via mTLS
test-consume user="portfolio-consumer":
    kubectl run kafka-consumer --rm -it --image=quay.io/strimzi/kafka:latest-kafka-3.7.1 -n {{ namespace }} --restart=Never -- \
      bin/kafka-console-consumer.sh \
        --bootstrap-server core-kafka-bootstrap:9093 \
        --topic portfolio-wallet-events \
        --from-beginning \
        --consumer-property security.protocol=SSL \
        --consumer-property ssl.truststore.type=PEM \
        --consumer-property ssl.truststore.location=/tmp/ca.crt \
        --consumer-property ssl.keystore.type=PEM \
        --consumer-property ssl.keystore.location=/tmp/user.crt \
        --consumer-property ssl.key.location=/tmp/user.key \
        --consumer-property group.id=portfolio-test

# Remove everything
remove:
    kubectl delete -n {{ namespace }} -f users.yaml -f topics.yaml --ignore-not-found
    kubectl delete -n {{ namespace }} -f kafka.yaml -f broker.yaml -f controller.yaml --ignore-not-found
    @echo "Kafka cluster removed. PVCs may still exist:"
    kubectl get pvc -n {{ namespace }}
